# TubeRevival configuration
# Переименуйте этот файл в .env и заполните своими данными
# Rename this file to .env and fill with your data

# Обязательно / Required:
YOUTUBE_API_KEY=ваш_ключ_сюда

# Для OAuth 2.0 (пока не используется, но добавьте для будущих версий)
# OAuth 2.0 (not used yet, but add for future versions)
GOOGLE_CLIENT_ID=ваш_client_id_сюда
GOOGLE_CLIENT_SECRET=ваш_client_secret_сюда

# Язык интерфейса / Interface language (ru / en) – опционально
APP_LANG=ru